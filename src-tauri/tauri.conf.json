{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SoloLog",
  "version": "0.1.0",
  "identifier": "com.chaincode.sololog",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "resources": ["../dist"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {}
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
